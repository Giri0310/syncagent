# Generic Content Sync Agent Environment Variables

# Storage adapter: json | sqlite (json is recommended for serverless deployments)
STORAGE_ADAPTER=json

# Data directory for JSON storage (relative to project root)
DATA_DIR=./data

# API Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Cron secret for Vercel cron job protection
CRON_SECRET=

# Optional: Database URL for SQLite or Postgres in production
DATABASE_URL=